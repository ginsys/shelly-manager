Usage Example:
```typescript
import { useError } from '@/composables/useError'
import ErrorDisplay from '@/components/shared/ErrorDisplay.vue'

const { error, hasError, setError, clearError } = useError()

try {
  await someOperation()
} catch (err) {
  setError(err, { action: 'Loading data', resource: 'devices' })
}

// In template:
<ErrorDisplay :error="error" @retry="retryOperation" @dismiss="clearError" />
```

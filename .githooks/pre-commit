#!/bin/bash
#
# Pre-commit hook: format staged Go files and run the lint suite (parity with CI).
# Installed by `make hooks-install`, which copies this file to .git/hooks/.
#
# Tooling is routed through `mise` when it is available, so the hook works
# whether the Go toolchain is on PATH directly or only via mise (this repo pins
# its toolchain in mise.toml). Contributors without mise fall back to PATH.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Decide once how to invoke tooling. Prefer mise (this repo pins its toolchain
# in mise.toml), but only if it is installed AND can actually load the project
# config — the `sh -c 'exit 0'` probe fails when mise.toml is untrusted or
# unloadable. Otherwise fall back to PATH so contributors who have gofmt/go/
# golangci-lint available directly are never blocked.
if command -v mise >/dev/null 2>&1 && mise exec -- sh -c 'exit 0' >/dev/null 2>&1; then
	RUNNER="mise exec --"
else
	RUNNER=""
fi

# run executes a command through the selected runner (mise or PATH).
run() {
	$RUNNER "$@"
}

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Only Go files are formatted/linted here.
go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$go_files" ]; then
	echo -e "${GREEN}No Go files to check.${NC}"
	exit 0
fi

echo -e "${YELLOW}Checking Go files:${NC}"
echo "$go_files"

# Refuse partially staged Go files. Formatting rewrites the working tree, and
# restaging (git add below) would then sweep in the unstaged hunks too — a
# silent commit of unstaged work. A Go file that also has unstaged changes is
# exactly this case. Go paths in this repo do not contain spaces, so
# word-splitting the list into arguments is safe.
# shellcheck disable=SC2086
partial=$(comm -12 \
	<(printf '%s\n' $go_files | sort -u) \
	<(git diff --name-only | sort -u))
if [ -n "$partial" ]; then
	echo -e "${RED}Refusing to commit: these Go files are partially staged:${NC}"
	echo "$partial"
	echo -e "${RED}Formatting would also stage their unstaged changes. Stage them fully (git add) or stash the rest, then commit.${NC}"
	exit 1
fi

# Format every staged Go file and restage. gofmt always; goimports too when
# available, so import-only issues are auto-fixed rather than only flagged by
# lint. Restaging is safe here because no file has unstaged hunks (checked
# above). Formatting is idempotent, so running unconditionally is fine.
# shellcheck disable=SC2086
run gofmt -w $go_files
if run sh -c 'command -v goimports >/dev/null 2>&1'; then
	# shellcheck disable=SC2086
	run goimports -w $go_files
fi
# shellcheck disable=SC2086
git add $go_files
echo -e "${GREEN}Formatted and restaged.${NC}"

# Run the same lint suite as CI (go vet + golangci-lint over the module).
echo -e "${YELLOW}Running lint suite (make lint)...${NC}"
if ! run make lint; then
	echo -e "${RED}Linting failed. Please fix issues before committing.${NC}"
	exit 1
fi

echo -e "${GREEN}Pre-commit checks passed!${NC}"
exit 0

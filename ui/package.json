{
  "name": "shelly-manager-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "PLAYWRIGHT_WORKERS=2 playwright test --workers=2",
    "test:e2e:dev": "playwright test --config=playwright-dev.config.ts",
    "test:e2e:dev:ui": "playwright test --config=playwright-dev.config.ts --ui",
    "test:e2e:dev:debug": "playwright test --config=playwright-dev.config.ts --debug",
    "test:e2e:dev:headed": "playwright test --config=playwright-dev.config.ts --headed",
    "test:e2e:smoke": "playwright test --config=playwright-smoke.config.ts",
    "test:e2e:critical": "playwright test tests/e2e/critical --workers=2",
    "test:e2e:quick": "playwright test tests/e2e/smoke tests/e2e/critical --workers=2",
    "test:e2e:full": "playwright test --workers=2",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:install": "playwright install"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "pako": "^3.0.1",
    "pinia": "^3.0.4",
    "quasar": "^2.21.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@types/pako": "^2.0.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.4"
  }
}
